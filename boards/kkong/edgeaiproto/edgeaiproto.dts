/dts-v1/;
#include <st/u5/stm32u585Xi.dtsi>
#include <st/u5/stm32u585ritx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
    model = "Kenneth Kong's Edge AI Prototype board";
    compatible = "kkong,edgeaiproto";

    chosen {
        zephyr,console = &usart1;
        zephyr,shell-uart = &usart1;
        zephyr,uart-mcumgr = &usart1;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &slot0_partition;
    };

    leds {
		compatible = "gpio-leds";

		green_led_1: led_1 {
			gpios = <&gpioc 10 GPIO_ACTIVE_LOW>;
			label = "GRN LED";
		};

		red_led_1: led_2 {
			gpios = <&gpioc 12 GPIO_ACTIVE_LOW>;
			label = "RED LED";
		};
	};

    gpio_keys {
		compatible = "gpio-keys";

		user_button_sec: button_1 {
			label = "User Btn 1";
			gpios = <&gpioa 2 (GPIO_ACTIVE_HIGH)>;
			zephyr,code = <INPUT_KEY_0>;
		};
        
        user_button_pri: button_2 {
			label = "User Btn 2";
			gpios = <&gpioa 3 (GPIO_ACTIVE_HIGH)>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};

    aliases {
        led0 = &green_led_1;
        led1 = &red_led_1;
        sw0 = &user_button_pri;
        sw1 = &user_button_sec;
    };
};

/* Clock configuration - STM32U585 can run up to 160MHz */
&clk_hsi48 {
    status = "okay";
};

/* &clk_lse {
    status = "okay";
}; */

&clk_msis {
    status = "okay";
    msi-range = <4>;  /* 4MHz */
    msi-pll-mode;
};

&pll1 {
    div-m = <1>;
    mul-n = <80>;
    div-q = <2>;
    div-r = <2>;
    clocks = <&clk_msis>;
    status = "okay";
};

&rcc {
    clocks = <&pll1>;
    clock-frequency = <DT_FREQ_M(160)>;
    ahb-prescaler = <1>;
    apb1-prescaler = <1>;
    apb2-prescaler = <1>;
    apb3-prescaler = <1>;
};

/* USART1 for console - adjust pins to your design */
&usart1 {
    pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
    pinctrl-names = "default";
    current-speed = <921600>;
    status = "okay";
};

/* Flash partitions */
&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x00000000 DT_SIZE_K(64)>;
        };
        slot0_partition: partition@10000 {
            label = "image-0";
            reg = <0x00010000 DT_SIZE_K(768)>;
        };
        slot1_partition: partition@d0000 {
            label = "image-1";
            reg = <0x000d0000 DT_SIZE_K(768)>;
        };
        storage_partition: partition@190000 {
            label = "storage";
            reg = <0x00190000 DT_SIZE_K(64)>;
        };
    };
};

/* Enable other peripherals as needed */
&gpioa {
    status = "okay";
};

&gpiob {
    status = "okay";
};

&gpioc {
    status = "okay";
};

&spi1 {
	pinctrl-0 = <&spi1_nss_pa15 &spi1_sck_pb3
		     &spi1_miso_pb4 &spi1_mosi_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c3 {
    pinctrl-0 = <&i2c3_scl_pc0 &i2c3_sda_pc1>;
    pinctrl-names = "default";
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;
};
